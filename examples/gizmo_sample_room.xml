<mujoco model="sample_room">
  <!-- A stand-in MJCF in the same shape Antim/Gizmo exports (floor plane + box
       obstacles + a red sphere). Load it via the visualizer's "Load MJCF file"
       button to exercise the Antim import path without waiting on generation. -->
  <worldbody>
    <geom name="floor" type="plane" size="4 4 0.1" pos="0 0 0" rgba="0.4 0.4 0.4 1"/>
    <body name="shelf"   pos="-1 1 0.4"><geom type="box" size="0.5 0.8 0.4"/></body>
    <body name="crate"   pos="1.5 -0.5 0.3"><geom type="box" size="0.6 0.6 0.3"/></body>
    <body name="counter" pos="0 2.5 0.4"><geom type="box" size="1.2 0.3 0.4"/></body>
    <body name="pillar"  pos="2.5 2 0.5"><geom type="box" size="0.4 0.9 0.5"/></body>
    <body name="red_ball" pos="3 -3 0.12"><geom type="sphere" size="0.12" rgba="1 0 0 1"/></body>
  </worldbody>
</mujoco>
